# At least one of ANTHROPIC_API_KEY or OPENAI_API_KEY is required.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Optional – defaults shown
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=16384
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# Authentication (leave blank to disable)
AUTH_TOKEN=

# MCP Explorer source root
SRC_ROOT=

# Persistence
DATABASE_URL=sqlite+aiosqlite:///./data/fast_code.db

# CORS
ALLOWED_ORIGINS=*

# PTY / WebSocket terminal
MAX_SESSIONS=10

# Working directory for tool operations (Bash, Glob, Grep default here).
# Set to the root of the project you want the AI to work on.
WORK_DIR=/path/to/your/project
